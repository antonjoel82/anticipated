{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "anticipated/react": ["../src/react/index.ts"],
      "anticipated/core": ["../src/core/index.ts"]
    }
  },
  "include": ["./**/*.ts", "./**/*.tsx"]
}
